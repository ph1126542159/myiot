build bin/macchina: CXX_EXECUTABLE_LINKER__macchina_Debug server/CMakeFiles/macchina.dir/src/MacchinaServer.cpp.o | lib/libPocoOSPd.a lib/libPocoZipd.a lib/libPocoUtild.a lib/libPocoJSONd.a lib/libPocoXMLd.a lib/libPocoFoundationd.a || lib/libPocoFoundationd.a lib/libPocoJSONd.a lib/libPocoOSPd.a lib/libPocoUtild.a lib/libPocoXMLd.a lib/libPocoZipd.a
  CONFIG = Debug
  FLAGS = -g
  LINK_LIBRARIES = lib/libPocoOSPd.a  lib/libPocoZipd.a  lib/libPocoUtild.a  lib/libPocoJSONd.a  lib/libPocoXMLd.a  lib/libPocoFoundationd.a  -lpthread  -ldl  -lrt
  OBJECT_DIR = server/CMakeFiles/macchina.dir
  POST_BUILD = cd /home/ph/work/myiot/build-linux-local/server && /home/ph/.local/myiot-toolchain/tools/cmake/bin/cmake -E copy_if_different /home/ph/work/myiot/server/macchina.properties /home/ph/work/myiot/build-linux-local/bin/macchina.properties && /home/ph/.local/myiot-toolchain/tools/cmake/bin/cmake -E copy_if_different /home/ph/work/myiot/server/macchina.pem /home/ph/work/myiot/build-linux-local/bin/macchina.pem && /home/ph/.local/myiot-toolchain/tools/cmake/bin/cmake -E copy_if_different /home/ph/work/myiot/server/rootcert.pem /home/ph/work/myiot/build-linux-local/bin/rootcert.pem
  PRE_LINK = :
  TARGET_FILE = bin/macchina
  TARGET_PDB = macchina.dbg
  TARGET_SUPPORT_DIR = server/CMakeFiles/macchina.dir


#############################################
# Utility command for package

build server/CMakeFiles/package.util: CUSTOM_COMMAND server/all
  COMMAND = cd /home/ph/work/myiot/build-linux-local && /home/ph/.local/myiot-toolchain/tools/cmake/bin/cpack --config ./CPackConfig.cmake
  DESC = Run CPack packaging tool...
  pool = console
  restat = 1

build server/package: phony server/CMakeFiles/package.util


#############################################
# Utility command for package_source

build server/CMakeFiles/package_source.util: CUSTOM_COMMAND
  COMMAND = cd /home/ph/work/myiot/build-linux-local && /home/ph/.local/myiot-toolchain/tools/cmake/bin/cpack --config ./CPackSourceConfig.cmake
  DESC = Run CPack packaging tool for source...
  pool = console
  restat = 1

build server/package_source: phony server/CMakeFiles/package_source.util


#############################################
# Utility command for edit_cache

build server/CMakeFiles/edit_cache.util: CUSTOM_COMMAND
  COMMAND = cd /home/ph/work/myiot/build-linux-local/server && /home/ph/.local/myiot-toolchain/tools/cmake/bin/ccmake -S/home/ph/work/myiot -B/home/ph/work/myiot/build-linux-local
  DESC = Running CMake cache editor...
  pool = console
  restat = 1

build server/edit_cache: phony server/CMakeFiles/edit_cache.util


#############################################
# Utility command for rebuild_cache

build server/CMakeFiles/rebuild_cache.util: CUSTOM_COMMAND
  COMMAND = cd /home/ph/work/myiot/build-linux-local/server && /home/ph/.local/myiot-toolchain/tools/cmake/bin/cmake --regenerate-during-build -S/home/ph/work/myiot -B/home/ph/work/myiot/build-linux-local
  DESC = Running CMake to regenerate build system...
  pool = console
  restat = 1

build server/rebuild_cache: phony server/CMakeFiles/rebuild_cache.util


#############################################
# Utility command for list_install_components

build server/list_install_components: phony


#############################################
# Utility command for install

build server/CMakeFiles/install.util: CUSTOM_COMMAND server/all
  COMMAND = cd /home/ph/work/myiot/build-linux-local/server && /home/ph/.local/myiot-toolchain/tools/cmake/bin/cmake -P cmake_install.cmake
  DESC = Install the project...
  pool = console
  restat = 1

build server/install: phony server/CMakeFiles/install.util


#############################################
# Utility command for install/local

build server/CMakeFiles/install/local.util: CUSTOM_COMMAND server/all
  COMMAND = cd /home/ph/work/myiot/build-linux-local/server && /home/ph/.local/myiot-toolchain/tools/cmake/bin/cmake -DCMAKE_INSTALL_LOCAL_ONLY=1 -P cmake_install.cmake
  DESC = Installing only the local directory...
  pool = console
  restat = 1

build server/install/local: phony server/CMakeFiles/install/local.util


#############################################
# Utility command for install/strip

build server/CMakeFiles/install/strip.util: CUSTOM_COMMAND server/all
  COMMAND = cd /home/ph/work/myiot/build-linux-local/server && /home/ph/.local/myiot-toolchain/tools/cmake/bin/cmake -DCMAKE_INSTALL_DO_STRIP=1 -P cmake_install.cmake
  DESC = Installing the project stripped...
  pool = console
  restat = 1

build server/install/strip: phony server/CMakeFiles/install/strip.util

