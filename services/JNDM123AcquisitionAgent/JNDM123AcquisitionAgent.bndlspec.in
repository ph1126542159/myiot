<bundlespec>
  <manifest>
    <name>MyIoT JNDM123 Acquisition Service</name>
    <symbolicName>@MYIOT_SERVICE_BUNDLE_NAME@</symbolicName>
    <version>@MYIOT_SERVICE_PACKAGE_VERSION@</version>
    <vendor>MyIoT</vendor>
    <copyright>(c) 2026 MyIoT</copyright>
    <activator>
      <class>MyIoT::Services::JNDM123AcquisitionAgent::BundleActivator</class>
      <library>@MYIOT_SERVICE_BUNDLE_NAME@</library>
    </activator>
    <lazyStart>false</lazyStart>
    <runLevel>615</runLevel>
  </manifest>
  <code>
    bin/${osName}/${osArch}/*.so,
    bin/${osName}/${osArch}/*.dylib,
    bin/${osName}/${osArch}/*.dll,
    bin/${osName}/${osArch}/*.pdb,
  </code>
</bundlespec>
