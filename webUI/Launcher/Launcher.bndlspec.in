<bundlespec>
  <manifest>
    <name>MyIoT WebUI Launcher</name>
    <symbolicName>@MYIOT_WEBUI_PACKAGE_BUNDLE_NAME@</symbolicName>
    <version>@MYIOT_WEBUI_PACKAGE_VERSION@</version>
    <vendor>MyIoT</vendor>
    <copyright>(c) 2026 MyIoT</copyright>
    <activator>
      <class>MyIoT::WebUI::Launcher::BundleActivator</class>
      <library>@MYIOT_WEBUI_PACKAGE_BUNDLE_NAME@</library>
    </activator>
    <lazyStart>false</lazyStart>
    <runLevel>615</runLevel>
    <dependency>
      <symbolicName>osp.web</symbolicName>
      <version>[1.1.0,3.0.0)</version>
    </dependency>
  </manifest>
  <code>
    bin/${osName}/${osArch}/*.so,
    bin/${osName}/${osArch}/*.dylib,
    bin/${osName}/${osArch}/*.dll,
    bin/${osName}/${osArch}/*.pdb,
  </code>
  <files>
    bundle/*
  </files>
</bundlespec>
